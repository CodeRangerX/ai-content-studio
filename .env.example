# ============================================
# 前端环境变量 (VITE_*)
# ============================================

# Google OAuth 配置
# 1. 访问 https://console.cloud.google.com/apis/credentials
# 2. 创建 OAuth 2.0 客户端 ID
# 3. 添加授权 JavaScript 来源：https://main.ai-content-studio-am5.pages.dev
# 4. 添加授权重定向 URI：https://main.ai-content-studio-am5.pages.dev
# 5. 复制客户端 ID 到下方
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# API 基础 URL（可选，默认使用相对路径）
VITE_API_URL=https://your-api.railway.app

# ============================================
# 后端环境变量 (server/)
# ============================================

# JWT 密钥（生产环境必须设置！）
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-secure-refresh-secret-at-least-32-chars

# Google OAuth Client ID（用于验证 Google 登录）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 前端 URL（用于 CORS 和回调）
FRONTEND_URL=https://main.ai-content-studio-am5.pages.dev

# Resend 邮件服务
RESEND_API_KEY=re_xxx

# PayPal 配置
PAYPAL_MODE=sandbox  # sandbox 或 live
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_PLAN_MONTHLY=P-xxx  # 月付计划 ID
PAYPAL_PLAN_YEARLY=P-xxx   # 年付计划 ID
PAYPAL_WEBHOOK_ID=xxx      # 从 PayPal Dashboard 获取
PAYPAL_PRODUCT_ID=PROD-xxx # 产品 ID（可选）

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat